{
    "name": "imc/backend",
    "description": "IMC Backend - User Permission Management API",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.0",
        "firebase/php-jwt": "^6.10",
        "illuminate/database": "^10.0",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Imc\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Imc\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
