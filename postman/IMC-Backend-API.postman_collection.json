{
  "info": {
    "name": "IMC Backend API",
    "description": "REST API for User Permission Management.\n\n**Auth Flow:** POST /auth/login using seed admin credentials (admin / admin123) → copy token → use in all /api/* requests.\n\n**Environment variables needed:**\n- `base_url`: http://localhost:8080\n- `token`: (auto-set by Login request test script)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Login success\", function () {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data && jsonData.data.token) {",
                  "        pm.environment.set(\"token\", jsonData.data.token);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"admin\", \"password\": \"admin123\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Levels",
      "item": [
        {
          "name": "List Levels",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/levels",
              "host": ["{{base_url}}"],
              "path": ["api", "levels"]
            }
          }
        },
        {
          "name": "List Levels (Filtered)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/levels?search=Super&is_active=1",
              "host": ["{{base_url}}"],
              "path": ["api", "levels"],
              "query": [
                {"key": "search", "value": "Super"},
                {"key": "is_active", "value": "1"}
              ]
            }
          }
        },
        {
          "name": "Get Level",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/levels/1",
              "host": ["{{base_url}}"],
              "path": ["api", "levels", "1"]
            }
          }
        },
        {
          "name": "Create Level",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/levels",
              "host": ["{{base_url}}"],
              "path": ["api", "levels"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"nama_level\": \"Test Level\", \"deskripsi\": \"Created via Postman\", \"is_active\": true}"
            }
          }
        },
        {
          "name": "Update Level",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/levels/1",
              "host": ["{{base_url}}"],
              "path": ["api", "levels", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"nama_level\": \"Super Admin\"}"
            }
          }
        },
        {
          "name": "Delete Level",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/levels/4",
              "host": ["{{base_url}}"],
              "path": ["api", "levels", "4"],
              "description": "Delete Viewer level (id=4). Soft-deletes, sets deleted_at."
            }
          }
        }
      ]
    },
